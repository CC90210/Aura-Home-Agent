# Home Assistant
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# Govee LED API
GOVEE_API_KEY=your_govee_api_key_here

# Spotify
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ElevenLabs TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_preferred_voice_id

# Claude API (for AURA voice agent intent processing)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Clap Detection
CLAP_WEBHOOK_SECRET=your_webhook_secret_here

# Network / Deployment
PI_HOST=homeassistant.local
PI_USER=root

# Web Dashboard (used in dashboard/.env.local — copy these values there)
# NEXT_PUBLIC_HA_URL is the HA URL that the browser will reach directly
NEXT_PUBLIC_HA_URL=http://homeassistant.local:8123
# HA_TOKEN stays server-side — do NOT expose it to the browser

# Adaptive Learning (SQLite path on Pi — relative to /config/aura)
AURA_DB_PATH=/config/aura/data/patterns.db
AURA_VOICE_PIN=change_me

# OpenAI Whisper (optional — if using cloud STT instead of local faster-whisper)
# OPENAI_API_KEY=your_openai_api_key_here

# ---------------------------------------------------------------------------
# Dashboard Authentication
# ---------------------------------------------------------------------------
# Set this to a strong, randomly generated access code.
# Gate the AURA web dashboard so only CC and Adon can access it.
# Used in dashboard/.env.local (copy this value there).
#
# Generate with: openssl rand -base64 32
# Leave empty to disable (development only).
#
DASHBOARD_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Bravo Bridge (Business-Empire-Agent integration)
# ---------------------------------------------------------------------------
# Connects AURA to CC's business data: MRR, client health, content calendar.
# Only needed for Conaugh's pulse checks — Adon doesn't use this.
# Get these values from Business-Empire-Agent/.env.agents
#
BRAVO_SUPABASE_URL=https://phctllmtsogkovoilwos.supabase.co
BRAVO_SUPABASE_SERVICE_ROLE_KEY=your_bravo_service_role_key_here
