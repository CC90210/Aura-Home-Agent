# ===========================================================================
# AURA by OASIS — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Variables marked [REQUIRED] must be set for core functionality.
# Variables marked [OPTIONAL] enable additional features but aren't needed
# for the system to start.
# ===========================================================================

# ---------------------------------------------------------------------------
# [REQUIRED] Home Assistant
# ---------------------------------------------------------------------------
# Get your token: HA web UI -> Profile -> Long-Lived Access Tokens -> Create
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# ---------------------------------------------------------------------------
# [REQUIRED] Claude API — powers AURA's intelligence
# ---------------------------------------------------------------------------
# Get your key: console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------------------------------------------------------
# [REQUIRED] ElevenLabs TTS — gives AURA her voice
# ---------------------------------------------------------------------------
# Get your key: elevenlabs.io -> Profile -> API Keys
# Get a voice ID: elevenlabs.io -> Voices -> pick one -> copy ID
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_preferred_voice_id

# ---------------------------------------------------------------------------
# [OPTIONAL] Govee LED API — direct LED control (also works through HA)
# ---------------------------------------------------------------------------
# Get your key: Govee Home app -> Profile -> About -> Apply for API Key
GOVEE_API_KEY=your_govee_api_key_here

# ---------------------------------------------------------------------------
# [OPTIONAL] Spotify — music integration (also configurable through HA)
# ---------------------------------------------------------------------------
# Get credentials: developer.spotify.com -> Create App
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ---------------------------------------------------------------------------
# [OPTIONAL] Clap Detection — webhook secret for HA automation triggers
# ---------------------------------------------------------------------------
CLAP_WEBHOOK_SECRET=your_webhook_secret_here

# ---------------------------------------------------------------------------
# [REQUIRED for deploy scripts] Pi Network Access
# ---------------------------------------------------------------------------
PI_HOST=homeassistant.local
PI_USER=root

# ---------------------------------------------------------------------------
# [REQUIRED for dashboard] Web Dashboard
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_HA_URL is what the BROWSER connects to (may differ from HA_URL)
NEXT_PUBLIC_HA_URL=http://homeassistant.local:8123

# Generate a strong auth token: openssl rand -base64 32
# Leave empty to disable auth (development only)
DASHBOARD_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# [REQUIRED] Voice Agent Security
# ---------------------------------------------------------------------------
# PIN for sensitive voice commands (lock doors, arm cameras)
# CHANGE THIS from the default before going live
AURA_VOICE_PIN=change_me

# ---------------------------------------------------------------------------
# [OPTIONAL] Bravo Bridge — Business-Empire-Agent integration
# ---------------------------------------------------------------------------
# Only needed for CC's business pulse checks. Skip if not using.
BRAVO_SUPABASE_URL=https://your-project.supabase.co
BRAVO_SUPABASE_SERVICE_ROLE_KEY=your_bravo_service_role_key_here

# ---------------------------------------------------------------------------
# [AUTO] Paths — usually don't need to change these
# ---------------------------------------------------------------------------
# SQLite database path (relative to /config/aura on Pi, auto-created locally)
AURA_DB_PATH=data/patterns.db
