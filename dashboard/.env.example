# Home Assistant — server-side only (never exposed to the browser)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# Home Assistant — safe to expose (URL only, no credentials)
# Used by the browser to construct WebSocket connections
NEXT_PUBLIC_HA_URL=http://homeassistant.local:8123

# ---------------------------------------------------------------------------
# Dashboard Authentication
# ---------------------------------------------------------------------------
# Set this to a strong, randomly generated access code.
# CC and Adon must enter this code once when opening the dashboard on a new
# device. The code is stored in an httpOnly cookie for 30 days.
#
# Generate a strong value with: openssl rand -base64 32
#
# Leave empty (or unset) to disable authentication — only do this during
# local development. Always set this in Vercel environment variables for
# any public-facing deployment.
#
DASHBOARD_AUTH_TOKEN=
