[Unit]
Description=AURA Voice Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/config/aura/voice-agent
ExecStart=/config/aura/.venv/bin/python aura_voice.py
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
